# Configure this file with real secrets before building/running the Docker image.

# Database
DATABASE_URL="postgres://username:password@postgres:5432/otpbud"

# Postgres
POSTGRES_USER="username"
POSTGRES_PASSWORD="password"
POSTGRES_DB="otpbud"

# JWT
JWT_SECRET="your-jwt-secret"
NODE_ENV="production" # or development depending on your environment

# SMTP (mailer)
SMTP_HOST="smtp.example.com"
SMTP_USER="you@example.com"
SMTP_PASS="super-secret-pw"
SMTP_FROM='"OTP Bud" <no-reply@example.com>'
SMTP_PORT=587
SMTP_SECURE=false

# Redis (optional: point at hosted redis)
REDIS_HOST=redis
REDIS_PORT=6379

# Frontend (used by Vite when building the client)
VITE_API_URL=http://localhost:3000/api/v1
