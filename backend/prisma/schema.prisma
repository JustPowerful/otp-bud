// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String @id @default(cuid())
  firstname String
  lastname  String

  tokens       Token[] // The tokens associated with the user
  applications Application[] // The applications owned by the user

  accountId String
  account   Account @relation(fields: [accountId], references: [id])
}

model Account {
  id       String  @id @default(cuid())
  email    String? @unique
  password String?

  user User[] // The users associated with the account

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Token {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  account   User      @relation(fields: [userId], references: [id])
  expiresAt DateTime?
}

model Application {
  id          String  @id @default(cuid())
  name        String
  picture     String?
  description String?

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  templates Template[] // The email templates associated with the application

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Email templates for OTP messages
model Template {
  id      String @id @default(cuid())
  name    String @unique // Identifies the template later in the API calls for the developers
  subject String // The subject of the email
  body    String // The body of the email, can contain placeholders for dynamic content like {{otp}} or {{appName}}

  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // NOTE: One template can be active at a time for an application, but we keep the old ones for historical purposes and in case the developer wants to switch back to an old template
  isActive Boolean @default(true) // Indicates if the template is active or not

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
