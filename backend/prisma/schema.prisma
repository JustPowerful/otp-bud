// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String @id @default(cuid())
  firstname String
  lastname  String
  
  tokens Token[] // The tokens associated with the user
  applications Application[] // The applications owned by the user

  accountId String
  account   Account @relation(fields: [accountId], references: [id])
}

model Account {
  id       String  @id @default(cuid())
  email    String? @unique
  password String?

  user User[] // The users associated with the account

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Token {
  id       String   @id @default(cuid())
  token     String   @unique
  userId String
  account   User  @relation(fields: [userId], references: [id])
  expiresAt DateTime?
}

model Application {
  id         String   @id @default(cuid())
  name        String
  picture     String?
  description String?

  ownerId String
  owner   User @relation(fields: [ownerId], references: [id]) 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}